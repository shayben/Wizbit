# Azure Computer Vision (for OCR)
# Create a resource at https://portal.azure.com -> Computer Vision
VITE_AZURE_VISION_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
VITE_AZURE_VISION_KEY=<your-vision-api-key>

# Azure Speech Service (for pronunciation assessment + text-to-speech)
# Create a resource at https://portal.azure.com -> Speech Service
VITE_AZURE_SPEECH_KEY=<your-speech-api-key>
VITE_AZURE_SPEECH_REGION=<your-azure-region>   # e.g. eastus, westeurope

# Azure Translator (for Hebrew translation)
# Create a resource at https://portal.azure.com -> Translator
VITE_AZURE_TRANSLATOR_KEY=<your-translator-api-key>
VITE_AZURE_TRANSLATOR_REGION=<your-azure-region>   # e.g. eastus, westeurope

# Azure OpenAI (for immersive moments text analysis)
# Create a resource at https://portal.azure.com -> Azure OpenAI
VITE_AZURE_OPENAI_ENDPOINT=https://<region>.api.cognitive.microsoft.com
VITE_AZURE_OPENAI_KEY=<your-openai-api-key>
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Azure Entra ID / MSAL (for Microsoft SSO)
# 1. Create an app registration at https://portal.azure.com -> Microsoft Entra ID -> App registrations
# 2. Under "Authentication" add a Single-page application redirect URI for your domain
#    (e.g. http://localhost:5173 for dev, https://your-app.com for production)
# 3. Under "API permissions" ensure openid, profile, email, and User.Read are granted
# If these are omitted the app works without sign-in (localStorage only).
VITE_AZURE_AD_CLIENT_ID=<your-entra-app-client-id>
VITE_AZURE_AD_TENANT_ID=common   # or your specific tenant ID for single-tenant apps

# Azure Cosmos DB (for cross-device progress tracking)
# 1. Create a Cosmos DB account (NoSQL API) at https://portal.azure.com -> Azure Cosmos DB
# 2. Create a database named "reading-assistant" (or set VITE_COSMOS_DATABASE)
# 3. Create a container named "progress" with partition key "/uid"
# 4. Under "Keys", copy the PRIMARY KEY value
# 5. Enable CORS for your domain under "CORS" in the Cosmos DB account settings
# If these are omitted the app falls back to localStorage-only storage.
VITE_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com
VITE_COSMOS_KEY=<your-cosmos-primary-key>
VITE_COSMOS_DATABASE=reading-assistant
VITE_COSMOS_CONTAINER=progress
