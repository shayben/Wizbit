# Azure Computer Vision (for OCR)
# Create a resource at https://portal.azure.com -> Computer Vision
VITE_AZURE_VISION_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
VITE_AZURE_VISION_KEY=<your-vision-api-key>

# Azure Speech Service (for pronunciation assessment + text-to-speech)
# Create a resource at https://portal.azure.com -> Speech Service
VITE_AZURE_SPEECH_KEY=<your-speech-api-key>
VITE_AZURE_SPEECH_REGION=<your-azure-region>   # e.g. eastus, westeurope

# Azure Translator (for Hebrew translation)
# Create a resource at https://portal.azure.com -> Translator
VITE_AZURE_TRANSLATOR_KEY=<your-translator-api-key>
VITE_AZURE_TRANSLATOR_REGION=<your-azure-region>   # e.g. eastus, westeurope

# Azure OpenAI (for immersive moments text analysis)
# Create a resource at https://portal.azure.com -> Azure OpenAI
VITE_AZURE_OPENAI_ENDPOINT=https://<region>.api.cognitive.microsoft.com
VITE_AZURE_OPENAI_KEY=<your-openai-api-key>
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Firebase (for SSO + cross-device progress tracking)
# Create a project at https://console.firebase.google.com
# Enable Authentication -> Google sign-in provider
# Enable Firestore Database
# Copy values from Project Settings -> General -> Your apps -> Web app
# If these are omitted the app works without sign-in (localStorage only).
VITE_FIREBASE_API_KEY=<your-firebase-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<your-project-id>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<your-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<your-project-id>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<your-messaging-sender-id>
VITE_FIREBASE_APP_ID=<your-firebase-app-id>
