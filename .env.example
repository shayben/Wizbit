# =====================================================================
# CLIENT (browser) environment vars — these end up in the public bundle.
# Only put PUBLIC identifiers here. NEVER put API keys here anymore.
# =====================================================================

# Azure Entra ID / MSAL (Microsoft SSO) — public client ID, safe to ship.
# 1. Create an app registration at https://portal.azure.com -> Microsoft Entra ID -> App registrations
# 2. Under "Authentication" add a Single-page application redirect URI for your domain
# 3. Under "API permissions" ensure openid, profile, email, and User.Read are granted
# If omitted the app works without sign-in (localStorage only, anonymous quota).
VITE_AZURE_AD_CLIENT_ID=<your-entra-app-client-id>
VITE_AZURE_AD_TENANT_ID=common   # or your specific tenant ID for single-tenant apps

# Google Sign-In (public client ID, safe to ship)
VITE_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>

# Optional: override the API base path. Defaults to "/api" which works on
# Azure Static Web Apps with managed Functions in the same deployment.
# VITE_API_BASE=/api


# =====================================================================
# SERVER (api/) environment vars — set these as Azure Static Web Apps
# Application Settings (Portal → SWA resource → Configuration), NOT here.
# A copy is also kept in api/local.settings.json for local dev (gitignored).
# =====================================================================
#
# Required for the API to function:
#   AZURE_VISION_ENDPOINT, AZURE_VISION_KEY
#   AZURE_SPEECH_KEY, AZURE_SPEECH_REGION
#   AZURE_TRANSLATOR_KEY, AZURE_TRANSLATOR_REGION
#   AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_KEY, AZURE_OPENAI_DEPLOYMENT (e.g. gpt-4o-mini)
#   AZURE_DALLE_DEPLOYMENT (optional; e.g. gpt-image-1)
#
# Required for auth verification (mirror the client values above, no VITE_ prefix):
#   AZURE_AD_CLIENT_ID, AZURE_AD_TENANT_ID
#   GOOGLE_CLIENT_ID
#
# Required for quota persistence (otherwise falls back to in-memory, single-instance only):
#   COSMOS_ENDPOINT, COSMOS_KEY
#   COSMOS_DATABASE=wizbit          (default)
#   COSMOS_USAGE_CONTAINER=usage    (default, auto-created with /uid partition + 90d TTL)
#   COSMOS_USERS_CONTAINER=users    (default, auto-created with /uid partition)
#
# Optional knobs:
#   ALLOW_ANONYMOUS=true                     # let unauthenticated users use a small free quota
#   ANONYMOUS_DAILY_LIMIT_MULTIPLIER=0.5     # anon limits = floor(free_limit * this)
#
# See api/local.settings.json.example for the local-dev template.
